# Fernet key used to encrypt sensitive settings at rest (currently the SMTP password).
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep this OUT of the data volume and OUT of git. Back it up securely — losing it
# makes encrypted secrets unrecoverable. docker compose auto-loads .env for ${VAR} below.
OPAL_FERNET_KEY=
